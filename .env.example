# Path to the local todos folder (synced via iCloud, backed by git).
# Convention: namespace it under "lifeops_" so the data is clearly tied
# to the lifeops codebase.
TODOS_DIR="$HOME/iCloud Drive/lifeops_todos"

# Backing GitHub repo for the todos data, e.g. <your-user>/lifeops_todos.
# Should be a PRIVATE repo, distinct from the public lifeops code repo.
TODOS_REPO=""

# Comma-separated owner namespaces for the household. "shared" is always
# included automatically. Examples:
#   TODOS_OWNERS="alice,bob"
#   TODOS_OWNERS="me"
TODOS_OWNERS="user-a,user-b"

# Default identity for the MCP server — must be one of TODOS_OWNERS
TODOS_USER="user-a"

# GitHub PAT with `repo` scope
GITHUB_TOKEN=""

# Anthropic API key (used by todos-agent via the Claude Code SDK)
ANTHROPIC_API_KEY=""

# Local port the MCP server listens on (Cloudflare Tunnel maps here)
MCP_PORT=8000

# Local log directory
LOG_DIR="$HOME/logs"

# Optional: file holding household background the agent should know about.
# Defaults to ~/.config/lifeops/owner_context.md if unset.
OWNER_CONTEXT_FILE=""
